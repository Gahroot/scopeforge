# Copy to .env for local development. .env is gitignored; never use VITE_* for secrets.
# Load it with Node 24's env-file support, e.g.:
#   node --env-file=.env --import tsx src/server/appServer.ts --dev-ui

# Leave false to run the app server without local model calls.
SCOPEFORGE_AGENT_ENABLED=false

# @kenkaiiii/gg-ai provider: anthropic, openai, gemini, glm, moonshot,
# deepseek, openrouter, minimax, or xiaomi.
# ScopeForge's proposal copilot is tuned for Kimi K2.6 (provider "moonshot").
SCOPEFORGE_AGENT_PROVIDER=moonshot
SCOPEFORGE_AGENT_MODEL=kimi-k2.6

# Prefer this scoped key for ScopeForge's local-only agent config.
SCOPEFORGE_AGENT_API_KEY=

# Provider-specific fallbacks if SCOPEFORGE_AGENT_API_KEY is unset.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
GLM_API_KEY=
ZAI_API_KEY=
Z_AI_API_KEY=
MOONSHOT_API_KEY=
KIMI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
MINIMAX_API_KEY=
XIAOMI_API_KEY=

# Optional gg-ai request defaults.
# Moonshot/Kimi OpenAI-compatible endpoint:
SCOPEFORGE_AGENT_BASE_URL=https://api.moonshot.ai/v1
SCOPEFORGE_AGENT_MAX_TOKENS=4096
SCOPEFORGE_AGENT_TEMPERATURE=0.2
SCOPEFORGE_AGENT_TOP_P=
SCOPEFORGE_AGENT_THINKING=
SCOPEFORGE_AGENT_CACHE_RETENTION=short
SCOPEFORGE_AGENT_WEB_SEARCH=false
SCOPEFORGE_AGENT_COMPACTION=false
SCOPEFORGE_AGENT_CLEAR_TOOL_USES=false
SCOPEFORGE_AGENT_PROMPT_CACHE_KEY=scopeforge-local
