{
  "name": "scopeforge",
  "version": "0.1.0",
  "description": "Turns a vague build request into a defensible, honest scope and price. Three-lens model: cost floor, value ceiling, market reconciliation.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "scopeforge": "./dist/cli/main.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "app:dev": "tsx src/server/appServer.ts --dev-ui",
    "app:server": "tsx src/server/appServer.ts",
    "build": "vite build && tsc",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e:collab": "vitest run src/server/collaborativeProposalWorkflow.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "scope": "node dist/cli/main.js",
    "proposal": "tsx src/cli/proposal.ts",
    "proposal:sample": "npm run proposal -- --input examples/proposals/triten-intake.json --brand nolan --out out/triten-proposal.pdf --html out/triten-proposal.html"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@kenkaiiii/gg-agent": "^4.6.2",
    "@kenkaiiii/gg-ai": "^4.6.2",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  }
}
